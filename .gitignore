# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Environment variables
.env

# MacOS folder attributes
.DS_Store

# IDEs
.vscode/
.idea/

# Other project specifics
__pycache__
*.pyc

# Local mapping files, DB, PDFs
*.pdf
*.docx
mapping_test.xlsx

# Folders to ignore
.agent/*
!/.agent/rules/
!/.agent/workflows/
!/.agent/skills/
.scratch/*
sample_docs/*
sandbox/*

# Root files: Ignore all by default and only allow specific ones
/*
!/.gitignore
!/pyproject.toml
!/requirements.txt
!/README.md
!/CHANGELOG.md

# Allow specific core directories
!/anonymizer/
!/docs/
!/scripts/
!/tests/
!/openspec/
!/sample_docs/
!/sandbox/
!/.agent/
